# File cấu hình môi trường — Backend SDN302
#
# HƯỚNG DẪN:
#   1. Copy file này thành .env trong thư mục backend/
#      > cp .env.example .env        (Linux/Mac)
#      > copy .env.example .env      (Windows)
#   2. Điền đầy đủ thông tin thực tế vào .env
#   3. KHÔNG bao giờ push file .env lên Git (đã có trong .gitignore)
#
# Liên hệ @thanhbinh để lấy MONGO_URI_ATLAS và JWT_SECRET cho môi trường team.

# ────────────────────────────────────────────────
# SERVER
# ────────────────────────────────────────────────

PORT=5000
NODE_ENV=development

# ────────────────────────────────────────────────
# DATABASE
#
# Backend tự động ưu tiên Atlas trước.
# Nếu Atlas không kết nối được (mạng chặn, mất internet...)
# sẽ tự fallback sang Local — không cần sửa code hay .env.
#
# Xem hướng dẫn đồng bộ 2 chiều tại: docs/DATABASE_SETUP.md
# ────────────────────────────────────────────────

# MongoDB Atlas — dùng khi có internet (ưu tiên 1)
# Lấy connection string tại: Atlas Dashboard → Connect → Connect your application
MONGO_URI_ATLAS=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/sdn302_db?retryWrites=true&w=majority&appName=Cluster0

# MongoDB Local — fallback khi Atlas không kết nối được (ưu tiên 2)
# Đảm bảo MongoDB service đang chạy: net start MongoDB  (Windows)
MONGO_URI_LOCAL=mongodb://localhost:27017/sdn302_db

# ────────────────────────────────────────────────
# AUTHENTICATION (JWT)
# ────────────────────────────────────────────────

# Tất cả thành viên PHẢI dùng CÙNG một JWT_SECRET
# (để token tạo trên máy người này có thể verify trên máy người khác)
JWT_SECRET=your_shared_jwt_secret_key_here
JWT_EXPIRE=7d
