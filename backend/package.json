{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend for SDN302 event/web application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "sync:to-local": "node src/seed/sync-db.js atlas-to-local",
    "sync:to-atlas": "node src/seed/sync-db.js local-to-atlas",
    "seed:teacher-basic": "node src/seed/teacher/teacher-basic.seed.js",
    "seed:add-students": "node src/seed/add-students.seed.js",
    "seed:teacher-schedule": "node src/seed/teacher/teacher-schedule.seed.js",
    "seed:full": "node src/seed/full-system.seed.js",
    "seed:full-test-data": "node src/seed/full-test-data.seed.js",
    "cleanup:full-test-data": "node src/seed/cleanup-full-test-data.js",
    "reset:full-test-data": "npm run cleanup:full-test-data && npm run seed:full-test-data",
    "seed:generate-fixed-sessions": "node src/seed/teacher/generate-fixed-sessions.seed.js",
    "seed:cleanup-excess-sessions": "node src/seed/cleanup-excess-sessions.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.3.1",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
